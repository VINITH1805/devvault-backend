{
  "openapi": "3.1.1",
  "info": {
    "title": "DevVault | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5282"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": [
          "DevVault"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/generate": {
      "post": {
        "tags": [
          "DevVault"
        ],
        "operationId": "GenerateReleaseNotes",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateReleaseRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/vault": {
      "post": {
        "tags": [
          "DevVault"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SaveReleaseRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/vault/history": {
      "get": {
        "tags": [
          "DevVault"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/vault/{id}": {
      "get": {
        "tags": [
          "DevVault"
        ],
        "operationId": "GetReleaseDetail",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/login": {
      "get": {
        "tags": [
          "DevVault"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/callback": {
      "get": {
        "tags": [
          "DevVault"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GenerateReleaseRequest": {
        "type": "object",
        "properties": {
          "rawGitDiff": {
            "type": "string"
          }
        }
      },
      "SaveReleaseRequest": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "rawInput": {
            "type": "string"
          },
          "markdownNotes": {
            "type": "string"
          },
          "socialPost": {
            "type": "string"
          },
          "semanticVersion": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "DevVault"
    }
  ]
}